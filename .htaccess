Options -Indexes

# ── Front Controller Routing ─────────────────────────────────────────────────
# Compatible con XAMPP local (/PROYECTO_SODICOL/) y Docker (/)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Detectar RewriteBase automáticamente según el entorno
    # En XAMPP local: /PROYECTO_SODICOL/  |  En Docker: /
    RewriteBase /

    # No reescribir si el archivo/directorio existe
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Reescribir todo lo demás al front controller
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# ── Seguridad adicional ───────────────────────────────────────────────────────
# Bloquear acceso directo a archivos .env
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear acceso a archivos de configuración sensibles
<FilesMatch "^(conexion\.php|seguridad\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Cabeceras de seguridad
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Bloquear acceso directo al directorio de logs
<IfModule mod_rewrite.c>
    RewriteRule ^logs/ - [F,L]
</IfModule>

# Deshabilitar errores PHP visibles (respaldo por si php.ini no lo hace)
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag display_startup_errors Off
</IfModule>
